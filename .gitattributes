# Auto detect text files and perform LF normalization
* text=auto

# Force LF for source code
*.cs    text eol=lf
*.csproj text eol=lf
*.slnx  text eol=lf
*.json  text eol=lf
*.md    text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.sh    text eol=lf

# Binary files
*.png   binary
*.jpg   binary
*.gif   binary
*.ico   binary
*.pdf   binary
*.zip   binary
