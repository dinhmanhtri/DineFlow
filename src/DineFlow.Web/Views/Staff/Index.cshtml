@model DineFlow.Web.Models.StaffIndexViewModel
@{
    ViewData["Title"]    = "Nhân viên";
    ViewData["Subtitle"] = "Quản lý danh sách nhân viên";
}

<!-- KPI -->
<div class="kpi-row" style="margin-bottom:24px;">
    <div class="kpi-card">
        <div class="kpi-icon" style="background:linear-gradient(135deg,#6366f1,#818cf8);">👥</div>
        <div class="kpi-body">
            <div class="kpi-value">@Model.TotalCount</div>
            <div class="kpi-label">Tổng nhân viên</div>
        </div>
    </div>
    <div class="kpi-card">
        <div class="kpi-icon" style="background:linear-gradient(135deg,#10b981,#34d399);">✅</div>
        <div class="kpi-body">
            <div class="kpi-value" style="color:#10b981;">@Model.ActiveCount</div>
            <div class="kpi-label">Đang hoạt động</div>
        </div>
    </div>
    <div class="kpi-card">
        <div class="kpi-icon" style="background:linear-gradient(135deg,#f59e0b,#fbbf24);">⏸️</div>
        <div class="kpi-body">
            <div class="kpi-value" style="color:#f59e0b;">@(Model.TotalCount - Model.ActiveCount)</div>
            <div class="kpi-label">Tạm ngưng</div>
        </div>
    </div>
</div>

@if (!Model.Staff.Any())
{
    <div class="empty-state">
        <div style="font-size:64px;margin-bottom:16px;">👥</div>
        <h3 style="margin:0 0 8px;">Chưa có dữ liệu nhân viên</h3>
        <p style="color:var(--text-muted);">Danh sách nhân viên sẽ hiển thị tại đây.</p>
    </div>
}
else
{
    <div class="table-container">
        <table class="table">
            <thead>
                <tr>
                    <th>Nhân viên</th>
                    <th>Email</th>
                    <th>Vai trò</th>
                    <th>Điện thoại</th>
                    <th>Ngày tạo</th>
                    <th>Trạng thái</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var staff in Model.Staff.OrderBy(s => s.Role).ThenBy(s => s.FullName))
                {
                    var (roleColor, roleIcon) = staff.Role switch
                    {
                        "Admin"   => ("#818cf8", "👑"),
                        "Waiter"  => ("#f59e0b", "🍽️"),
                        "Chef"    => ("#10b981", "👨‍🍳"),
                        "Cashier" => ("#3b82f6", "💰"),
                        _         => ("var(--text-muted)", "👤")
                    };
                    <tr style="@(staff.IsActive ? "" : "opacity:0.55;")">
                        <td>
                            <div style="display:flex;align-items:center;gap:12px;">
                                <div style="width:38px;height:38px;border-radius:50%;
                                           background:linear-gradient(135deg,#6366f1,#818cf8);
                                           display:flex;align-items:center;justify-content:center;
                                           font-weight:700;font-size:15px;color:#fff;flex-shrink:0;">
                                    @staff.FullName[0].ToString().ToUpper()
                                </div>
                                <span style="font-weight:600;">@staff.FullName</span>
                            </div>
                        </td>
                        <td style="color:var(--text-muted);">@staff.Email</td>
                        <td>
                            <span style="font-size:12px;font-weight:600;color:@roleColor;
                                        background:rgba(99,102,241,.1);border-radius:20px;padding:3px 10px;">
                                @roleIcon @staff.Role
                            </span>
                        </td>
                        <td style="color:var(--text-muted);">@(staff.PhoneNumber ?? "—")</td>
                        <td style="color:var(--text-muted);font-size:13px;">
                            @staff.CreatedAt.ToString("dd/MM/yyyy")
                        </td>
                        <td>
                            @if (staff.IsActive)
                            {
                                <span style="font-size:12px;font-weight:600;color:#10b981;
                                            background:rgba(16,185,129,.15);border-radius:20px;padding:3px 10px;">
                                    🟢 Hoạt động
                                </span>
                            }
                            else
                            {
                                <span style="font-size:12px;font-weight:600;color:var(--text-muted);
                                            background:rgba(100,116,139,.15);border-radius:20px;padding:3px 10px;">
                                    ⚫ Tạm ngưng
                                </span>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
