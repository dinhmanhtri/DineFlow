# .dockerignore — Loại trừ files không cần thiết khỏi Docker build context
#
# [KIẾN THỨC] Build context: toàn bộ files được gửi lên Docker daemon khi build
# → .dockerignore giống .gitignore nhưng cho Docker
# → Loại trừ bin/, obj/ → giảm context size → build nhanh hơn

# Build output
**/bin/
**/obj/

# Git
.git/
.gitignore
.gitattributes

# IDE
.idea/
.vscode/
*.user

# Agent config (không cần trong image)
.agents/

# Docs
README.md
*.md

# Test projects (không cần trong runtime image)
tests/

# Docker files (không cần copy vào image)
*.Dockerfile
docker-compose.yml
.dockerignore
